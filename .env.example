# Backend (server/.env for local / Vercel env vars for production)
PORT=5001
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/theforge?retryWrites=true&w=majority
JWT_SECRET=<your-jwt-secret>
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=<your-smtp-email>
SMTP_PASS=<your-smtp-password>
SMTP_FROM="THE FORGE" <noreply@theforge.in>
CLIENT_URL=http://localhost:5173
# For Vercel backend, set CLIENT_URL to your frontend Vercel URL

# Frontend (client/.env for local / Vercel env vars for production)
VITE_UPI_ID=<your-upi-id>
# For Vercel frontend, set VITE_API_URL to your backend Vercel URL (no trailing slash)
